ENVIRONMENT=production
APP_NAME=FinMate UZ API
API_PORT=8000
WEB_PORT=3000

POSTGRES_DB=finmate
POSTGRES_USER=finmate
POSTGRES_PASSWORD=replace-with-strong-database-password
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://finmate:replace-with-strong-database-password@postgres:5432/finmate
REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=replace-with-at-least-32-random-characters
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=14
CORS_ORIGINS=["https://your-dashboard-domain.example"]
DEFAULT_CURRENCY=UZS

TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
BOT_API_TOKEN=replace-with-random-internal-bot-api-token
API_BASE_URL=https://your-api-domain.example/api/v1
NEXT_PUBLIC_API_URL=https://your-api-domain.example/api/v1
TRANSCRIBER_PROVIDER=mock
TELEGRAM_WEBHOOK_URL=
