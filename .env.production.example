ENVIRONMENT=production
APP_NAME=FinMate UZ API
API_PORT=8000
WEB_PORT=3000

POSTGRES_DB=finmate
POSTGRES_USER=finmate
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD
