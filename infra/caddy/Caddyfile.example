# DNS prerequisites at name.com:
# - A @   -> 134.122.92.113
# - A www -> 134.122.92.113
# - A app -> 134.122.92.113
# - A api -> 134.122.92.113
#
# Caddy automatically issues and renews HTTPS certificates for these hosts.
# Keep Docker Compose API and web ports bound only to 127.0.0.1 so they are
# reachable by Caddy on the VPS but not exposed directly to the public internet.

finmates.app {
    redir https://app.finmates.app{uri} permanent
}

www.finmates.app {
    redir https://app.finmates.app{uri} permanent
}

app.finmates.app {
    reverse_proxy 127.0.0.1:3000
}

api.finmates.app {
    reverse_proxy 127.0.0.1:8000
}
